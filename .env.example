# Copie para .env e preencha (não commite o .env).

# --- run_local.py / experimental_listen_loopback.py ---
# URL do Incoming Webhook do canal Teams (mensagens aparecem neste chat).
TEAMS_INCOMING_WEBHOOK_URL=
# Alternativa (Power Automate): gatilho "Quando um pedido HTTP é recebido" — URL completo do POST.
# Se preencher, tem prioridade sobre TEAMS_INCOMING_WEBHOOK_URL. JSON: keyword, excerpt, when_iso.
# TEAMS_POWER_AUTOMATE_HTTP_URL=
#   Copie o URL COMPLETO do gatilho HTTP (com sig= na query). Só ?api-version=1 dá erro 401.

# experimental_listen_loopback.py: índice da Mixagem estéreo (LIST_AUDIO_DEVICES=1)
# Um índice ou vários separados por vírgula (tenta até abrir)
AUDIO_INPUT_DEVICE_INDEX=32,30,31,29
LISTEN_MODE=chunk
# Headset USB (ex. Razer): Mixagem estéreo Realtek sem sinal → use wasapi + PyAudioWPatch
# LOOPBACK_MODE=wasapi
# WASAPI_LOOPBACK_DEVICE_INDEX=35
#   (opcional: índice [Loopback] — LIST_AUDIO_DEVICES=1 lista; Chat vs Game)
# LISTEN_MODE=vad
# PYAUDIO_CHUNK_SEC=5
# SILENT_CHUNK_RMS=35
# KEYWORD_COOLDOWN_SEC=0
#   (padrão no script: 0 = alerta sempre; use ex. 90 para não repetir a mesma keyword em sequência)
# LOG_TRANSCRIPTS=1
#   (0 = não imprime linha [STT] após cada reconhecimento)
# SILENCE_MSG_EVERY=30
#   (blocos silenciosos entre aviso e aviso quando SHOW_HEARD=1)
# STT_LANGUAGE=pt-BR
#   (ex.: en-US se a reunião for sobretudo em inglês)
# DRY_RUN=1
#   (só teste no terminal; para enviar ao Teams, NÃO defina DRY_RUN ou comente esta linha)
# SHOW_HEARD=1
# DEBUG_STT=1
# ENERGY_SENSITIVITY=0.45
# Não ativar: sounddevice estável não expõe loopback WASAPI de forma fiável
# USE_WASAPI_LOOPBACK=1

# --- run_alerts.py (automação Graph; precisa app + admin consent + política Teams) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Object ID do utilizador que organiza as reuniões cujas transcrições queres (GUID).
MEETING_ORGANIZER_USER_ID=
